    "url": "http://wpa.qq.com/msgrd?v=3&uin=532192607&site=qq&menu=yes",
    "maintainer": "JLKB",
    "processor": "STM32F103",
    "board": "STM32_F103_STM32DUINO",
    "bootloader": "vibl",
    "usb": {
        "vid": "0xF001",
        "pid": "0x5009",
        "device_version": "0.0.1"
    },

    "matrix_pins": {
        "cols": ["A6", "A7", null ],
        "rows": ["A5", "B10", null ]
    },
